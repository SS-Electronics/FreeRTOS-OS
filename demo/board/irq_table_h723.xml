<?xml version="1.0" encoding="UTF-8"?>
<!--
  demo/board/irq_table_h723.xml — Demo board IRQ table for STM32H723ZGTx.

  Purpose
  ───────
  Provides the IRQ configuration for the H723 demo build and cppcheck analysis.
  Mirrors the peripherals declared in stm32h723_devboard.xml.

  Key H723 IRQ differences from F411
  ────────────────────────────────────
  • HAL timebase uses TIM6_DAC_IRQn (irqn=54) — TIM1_UP_TIM10_IRQn is F411 only.
  • USART3 is at irqn=39 (F411 has no USART3 dedicated IRQ).
  • BTN_USER is on PC13 → EXTI15_10_IRQn (irqn=40), not EXTI0.
  • All ISR priorities must be ≥ configLIBRARY_MAX_SYSCALL_IRQ_PRIORITY (5).

  Regenerate board headers:
    make demo-gen-h723              (from FreeRTOS-OS/)
-->

<irq_table board="demo_stm32h723">

  <!-- ═══════════════════════════════════════════════════════════════════════
       Software IRQ capacity — drives irq_hw_conf.h generation
       ═══════════════════════════════════════════════════════════════════════ -->

  <config max_uart="4"  uart_events="3"
          max_i2c="4"   i2c_events="3"
          max_spi="4"   spi_events="4"
          max_exti="16"
          notify_max_subs="4"/>

  <!-- ═══════════════════════════════════════════════════════════════════════
       UART peripherals
       ═══════════════════════════════════════════════════════════════════════ -->

  <uart dev_id="0" label="UART_APP"   irqn="USART1_IRQn" priority="5" hal_inst="USART1"/>
  <uart dev_id="1" label="UART_DEBUG" irqn="USART3_IRQn" priority="5" hal_inst="USART3"/>

  <!-- ═══════════════════════════════════════════════════════════════════════
       I2C peripherals
       ═══════════════════════════════════════════════════════════════════════ -->

  <i2c dev_id="0" label="I2C_SENSOR_BUS"
       irqn_ev="I2C1_EV_IRQn" priority_ev="6"
       irqn_er="I2C1_ER_IRQn" priority_er="6"
       hal_inst="I2C1"/>

  <!-- ═══════════════════════════════════════════════════════════════════════
       SPI peripherals
       ═══════════════════════════════════════════════════════════════════════ -->

  <spi dev_id="0" label="SPI_FLASH_BUS" irqn="SPI1_IRQn" priority="6" hal_inst="SPI1"/>

  <!-- ═══════════════════════════════════════════════════════════════════════
       GPIO EXTI lines
       ═══════════════════════════════════════════════════════════════════════ -->

  <!-- PC13 → EXTI line 13 → EXTI15_10_IRQn -->
  <exti line="13" label="BTN_USER" irqn="EXTI15_10_IRQn" priority="6"/>

  <!-- ═══════════════════════════════════════════════════════════════════════
       RCC peripheral clock enables
       ═══════════════════════════════════════════════════════════════════════ -->

  <sys_clk inst="SYSCFG"/>
  <sys_clk inst="PWR"/>
  <!-- H723 GPIO on AHB4 — gen_irq_table.py emits __HAL_RCC_GPIOx_CLK_ENABLE() -->
  <gpio_clk port="A"/>
  <gpio_clk port="B"/>
  <gpio_clk port="C"/>
  <gpio_clk port="D"/>
  <gpio_clk port="E"/>

  <!-- ═══════════════════════════════════════════════════════════════════════
       System / core IRQs
       ═══════════════════════════════════════════════════════════════════════ -->

  <sys name="SysTick" irqn="SysTick_IRQn" priority="15" action="set_priority"/>
  <sys name="PendSV"  irqn="PendSV_IRQn"  priority="15" action="set_priority"/>
  <sys name="SVCall"  irqn="SVCall_IRQn"  priority="14" action="set_priority"/>

  <!--
    HAL timebase on TIM6 (basic timer, irqn=54 on H723).
    TIM6_DAC_IRQHandler is the shared ISR for TIM6 and DAC underrun.
    FreeRTOS-OS routes it through the dispatch layer:
      dispatch="hal_timebase_stm32_irq_handler()"
  -->
  <sys name="TIM6_DAC"  irqn="TIM6_DAC_IRQn" priority="1"  action="enable"
       irq_id="TIM_TICK" flow="edge"
       dispatch="hal_timebase_stm32_irq_handler()"
       dispatch_include="&lt;drivers/hal/stm32/hal_timebase_stm32.h&gt;"/>

  <!-- ═══════════════════════════════════════════════════════════════════════
       STM32H723 peripheral vector table  (RM0468 Table 122)
       Only vectors that have dedicated handlers are listed; remaining
       positions resolve to Default_Handler via the weak alias mechanism.
       ═══════════════════════════════════════════════════════════════════════ -->

  <vector_table device="STM32H723">
    <entry irqn="0"   handler="WWDG_IRQHandler"               comment="Window Watchdog"/>
    <entry irqn="1"   handler="PVD_AVD_IRQHandler"            comment="PVD/AVD through EXTI"/>
    <entry irqn="2"   handler="RTC_TAMP_STAMP_CSS_LSE_IRQHandler" comment="RTC Tamper/Timestamp/CSS"/>
