    <entry irqn="46"  handler="TIM8_CC_IRQHandler"            comment="TIM8 Capture Compare"/>
    <entry irqn="47"  handler="DMA1_Stream7_IRQHandler"       comment="DMA1 Stream 7"/>
    <entry irqn="49"  handler="SDMMC1_IRQHandler"             comment="SDMMC1"/>
    <entry irqn="50"  handler="TIM5_IRQHandler"               comment="TIM5"/>
    <entry irqn="51"  handler="SPI3_IRQHandler"               comment="SPI3"/>
    <entry irqn="52"  handler="UART4_IRQHandler"              comment="UART4"/>
    <entry irqn="53"  handler="UART5_IRQHandler"              comment="UART5"/>
