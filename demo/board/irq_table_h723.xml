    <entry irqn="61"  handler="ETH_IRQHandler"                comment="Ethernet global"/>
    <entry irqn="62"  handler="ETH_WKUP_IRQHandler"           comment="Ethernet wakeup"/>
    <entry irqn="68"  handler="DMA2_Stream5_IRQHandler"       comment="DMA2 Stream 5"/>
    <entry irqn="69"  handler="DMA2_Stream6_IRQHandler"       comment="DMA2 Stream 6"/>
    <entry irqn="70"  handler="DMA2_Stream7_IRQHandler"       comment="DMA2 Stream 7"/>
    <entry irqn="71"  handler="USART6_IRQHandler"             comment="USART6"/>
    <entry irqn="72"  handler="I2C3_EV_IRQHandler"            comment="I2C3 Event"/>
    <entry irqn="73"  handler="I2C3_ER_IRQHandler"            comment="I2C3 Error"/>
