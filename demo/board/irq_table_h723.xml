    <entry irqn="19"  handler="FDCAN1_IT0_IRQHandler"         comment="FDCAN1 interrupt 0"/>
    <entry irqn="20"  handler="FDCAN2_IT0_IRQHandler"         comment="FDCAN2 interrupt 0"/>
    <entry irqn="21"  handler="FDCAN1_IT1_IRQHandler"         comment="FDCAN1 interrupt 1"/>
    <entry irqn="22"  handler="FDCAN2_IT1_IRQHandler"         comment="FDCAN2 interrupt 1"/>
    <entry irqn="23"  handler="EXTI9_5_IRQHandler"            comment="EXTI Lines 5-9"/>
    <entry irqn="24"  handler="TIM1_BRK_IRQHandler"           comment="TIM1 Break"/>
    <entry irqn="25"  handler="TIM1_UP_IRQHandler"            comment="TIM1 Update"/>
    <entry irqn="26"  handler="TIM1_TRG_COM_IRQHandler"       comment="TIM1 Trigger/Comm"/>
