INCLUDES += -I$(CURDIR)
INCLUDES += -I$(CURDIR)/lib

obj-y += lib/lib-fsm/fsm.o

# ── CMSIS-DSP ─────────────────────────────────────────────────────────────────
# dsp_config.mk is generated by scripts/arm_dsp_gen.py from app/board/dsp_dev.xml.
# Include it when APP_DIR is provided; the dash prefix silences the missing-file
# warning during standalone kernel builds that do not use the DSP library.
-include $(APP_DIR)/board/dsp_config.mk

DSP_ROOT := $(CURDIR)/lib/CMSIS-DSP

ifeq ($(CONFIG_ARM_DSP_ENABLED),1)

INCLUDES += -I$(DSP_ROOT)/Include
INCLUDES += -I$(DSP_ROOT)/PrivateInclude
INCLUDES += -I$(CURDIR)/arch/arm/CMSIS_6/CMSIS/Core/Include

ifeq ($(CONFIG_ARM_DSP_COMMON_TABLES),1)
obj-y += lib/CMSIS-DSP/Source/CommonTables/CommonTables.o
endif

ifeq ($(CONFIG_ARM_DSP_BASIC_MATH),1)
obj-y += lib/CMSIS-DSP/Source/BasicMathFunctions/BasicMathFunctions.o
endif

ifeq ($(CONFIG_ARM_DSP_COMPLEX_MATH),1)
obj-y += lib/CMSIS-DSP/Source/ComplexMathFunctions/ComplexMathFunctions.o
endif

ifeq ($(CONFIG_ARM_DSP_CONTROLLER),1)
obj-y += lib/CMSIS-DSP/Source/ControllerFunctions/arm_pid_init_f32.o
endif

ifeq ($(CONFIG_ARM_DSP_FAST_MATH),1)
obj-y += lib/CMSIS-DSP/Source/FastMathFunctions/FastMathFunctions.o
endif

ifeq ($(CONFIG_ARM_DSP_FILTERING),1)
obj-y += lib/CMSIS-DSP/Source/FilteringFunctions/FilteringFunctions.o
endif

ifeq ($(CONFIG_ARM_DSP_INTERPOLATION),1)
obj-y += lib/CMSIS-DSP/Source/InterpolationFunctions/InterpolationFunctions.o
endif

ifeq ($(CONFIG_ARM_DSP_MATRIX),1)
obj-y += lib/CMSIS-DSP/Source/MatrixFunctions/MatrixFunctions.o
endif

ifeq ($(CONFIG_ARM_DSP_STATISTICS),1)
obj-y += lib/CMSIS-DSP/Source/StatisticsFunctions/StatisticsFunctions.o
endif

ifeq ($(CONFIG_ARM_DSP_SUPPORT),1)
obj-y += lib/CMSIS-DSP/Source/SupportFunctions/SupportFunctions.o
endif

ifeq ($(CONFIG_ARM_DSP_TRANSFORM),1)
obj-y += lib/CMSIS-DSP/Source/TransformFunctions/TransformFunctions.o
endif

ifeq ($(CONFIG_ARM_DSP_BAYES),1)
obj-y += lib/CMSIS-DSP/Source/BayesFunctions/BayesFunctions.o
endif

ifeq ($(CONFIG_ARM_DSP_SVM),1)
obj-y += lib/CMSIS-DSP/Source/SVMFunctions/SVMFunctions.o
endif

ifeq ($(CONFIG_ARM_DSP_DISTANCE),1)
obj-y += lib/CMSIS-DSP/Source/DistanceFunctions/DistanceFunctions.o
endif

ifeq ($(CONFIG_ARM_DSP_QUATERNION),1)
obj-y += lib/CMSIS-DSP/Source/QuaternionMathFunctions/QuaternionMathFunctions.o
endif

ifeq ($(CONFIG_ARM_DSP_WINDOW),1)
obj-y += lib/CMSIS-DSP/Source/WindowFunctions/WindowFunctions.o
endif

endif # CONFIG_ARM_DSP_ENABLED