{
    // ─────────────────────────────────────────────────────────────────────────
    //  FreeRTOS-OS  —  VS Code Task Definitions
    //
    //  Keyboard shortcuts:
    //    Ctrl+Shift+B   →  default build task  ("build")
    //    Ctrl+Shift+P   →  "Tasks: Run Task"   (pick any task)
    //
    //  Task dependency graph for F5 (debug) flow:
    //
    //    detect-target ─┐
    //                   ├─► build-and-detect ─► [launch.json preLaunchTask]
    //    build ─────────┘
    //
    //  "detect-target" reads CONFIG_TARGET_MCU from include/config/autoconf.h
    //  and writes build/active_debug.cfg + arch/debug_cfg/active_target.svd.
    //  This is the equivalent of STM32CubeIDE's project-specific debug config
    //  but fully automatic — switch MCU via  make menuconfig, no IDE changes.
    // ─────────────────────────────────────────────────────────────────────────
    "version": "2.0.0",
    "tasks": [

        // ══════════════════════════════════════════════════════════════════════
        //  CORE: detect-target
        //  Reads CONFIG_TARGET_MCU from autoconf.h, writes:
        //    build/active_debug.cfg        (OpenOCD wrapper for the active MCU)
        //    arch/debug_cfg/active_target.svd  (symlink to MCU SVD)
        //    build/debug_env.json          (machine-readable properties)
        // ══════════════════════════════════════════════════════════════════════
        {
            "label": "detect-target",
            "detail": "Auto-detect CONFIG_TARGET_MCU → write build/active_debug.cfg",
            "type": "shell",
            "command": "python3 scripts/gen_active_debug.py",
            "options": { "cwd": "${workspaceFolder}" },
            "problemMatcher": [],
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "clear": true,
                "showReuseMessage": false
            }
        },

        // ══════════════════════════════════════════════════════════════════════
        //  CORE: build
        //  Compiles and links kernel + application.  Default Ctrl+Shift+B task.
        // ══════════════════════════════════════════════════════════════════════
        {
            "label": "build",
            "detail": "make all — compile & link (uses APP_DIR=../app automatically)",
            "type": "shell",
            "command": "make all",
            "options": { "cwd": "${workspaceFolder}" },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": [
                {
                    "owner": "gcc",
                    "fileLocation": ["relative", "${workspaceFolder}"],
                    "pattern": {
                        "regexp": "^(.+):(\\d+):(\\d+):\\s+(warning|error):\\s+(.+)$",
                        "file": 1,
                        "line": 2,
                        "column": 3,
                        "severity": 4,
                        "message": 5
                    }
                }
            ],
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "clear": true
            }
        },

        // ══════════════════════════════════════════════════════════════════════
        //  CORE: build-and-detect  (preLaunchTask for all Auto launch configs)
        //  Runs detect-target first, then build.  Mirrors the CubeIDE F5 flow:
        //  validate debug config → compile → flash → debug.
        // ══════════════════════════════════════════════════════════════════════
        {
            "label": "build-and-detect",
            "detail": "Detect target MCU, then build — used as preLaunchTask for Auto configs",
            "dependsOn": ["detect-target", "build"],
            "dependsOrder": "sequence",
            "problemMatcher": [],
            "presentation": {
                "reveal": "always",
                "panel": "dedicated"
            }
        },

        // ══════════════════════════════════════════════════════════════════════
        //  Build with custom board
        // ══════════════════════════════════════════════════════════════════════
        {
            "label": "build (custom board)",
            "detail": "make all CONFIG_BOARD=<name>  — prompts for board name",
            "type": "shell",
            "command": "make all CONFIG_BOARD=${input:boardName}",
            "options": { "cwd": "${workspaceFolder}" },
            "problemMatcher": ["$gcc"],
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "clear": true
            }
        },

        // ══════════════════════════════════════════════════════════════════════
        //  Flash (program + reset, no debug)
        //  Uses OPENOCD_TARGET resolved by the Makefile from CONFIG_TARGET_MCU.
        //  Depends on build so the ELF is always up-to-date.
        // ══════════════════════════════════════════════════════════════════════
        {
            "label": "flash",
            "detail": "Detect target → build → program via OpenOCD → reset (no debug)",
            "type": "shell",
            "command": "make flash",
            "options": { "cwd": "${workspaceFolder}" },
            "dependsOn": ["build-and-detect"],
            "problemMatcher": [],
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "clear": false
            }
        },

        // ══════════════════════════════════════════════════════════════════════
        //  Board BSP generation
        // ══════════════════════════════════════════════════════════════════════
        {
            "label": "board-gen",
            "detail": "Generate board_config.c + board_device_ids.h from board XML",
            "type": "shell",
            "command": "make board-gen",
            "options": { "cwd": "${workspaceFolder}" },
            "problemMatcher": [],
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "clear": true
            }
        },

        // ══════════════════════════════════════════════════════════════════════
        //  Clean
        // ══════════════════════════════════════════════════════════════════════
        {
            "label": "clean",
            "detail": "Remove build/ artifacts and generated BSP files",
            "type": "shell",
            "command": "make clean",
            "options": { "cwd": "${workspaceFolder}" },
            "group": "build",
            "problemMatcher": [],
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "clear": false
            }
        },

        // ══════════════════════════════════════════════════════════════════════
        //  Kconfig — interactive target/feature selection
        // ══════════════════════════════════════════════════════════════════════
        {
            "label": "menuconfig",
            "detail": "Open Kconfig ncurses menu — set CONFIG_TARGET_MCU, peripherals, etc.",
            "type": "shell",
            "command": "make menuconfig",
            "options": { "cwd": "${workspaceFolder}" },
            "problemMatcher": [],
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "clear": true
            }
        },

        // ══════════════════════════════════════════════════════════════════════
        //  Generate autoconf.h from .config
        //  Run after menuconfig (or after editing .config directly).
        // ══════════════════════════════════════════════════════════════════════
        {
            "label": "config-outputs",
            "detail": "Regenerate include/config/autoconf.h + autoconf.mk from .config",
            "type": "shell",
            "command": "make config-outputs",
            "options": { "cwd": "${workspaceFolder}" },
            "problemMatcher": [],
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            }
        },

        // ══════════════════════════════════════════════════════════════════════
        //  OpenOCD server — manual mode for the "Auto — Attach" launch config
        //  The "Auto — Build, Flash & Debug" config starts OpenOCD automatically;
        //  this task is only needed when you want a persistent server for Attach.
        // ══════════════════════════════════════════════════════════════════════
        {
            "label": "openocd-server",
            "detail": "Start OpenOCD GDB server on :3333 (for Attach mode)",
            "type": "shell",
            // detect-target must run first so active_debug.cfg exists
            "command": "python3 scripts/gen_active_debug.py && openocd -f build/active_debug.cfg -c \"gdb_port 3333\" -c \"telnet_port 4444\" -c \"tcl_port 6666\"",
            "options": { "cwd": "${workspaceFolder}" },
            "isBackground": true,
            "problemMatcher": {
                "owner": "openocd",
                "pattern": { "regexp": "^$" },
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": "Open On-Chip Debugger",
                    "endsPattern": "Listening on port 3333"
                }
            },
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "clear": true
            }
        },

        // ══════════════════════════════════════════════════════════════════════
        //  Install debug tools
        //  Downloads SVD files for all supported MCUs into arch/debug_cfg/.
        //  Run once after cloning.  Needs internet access.
        // ══════════════════════════════════════════════════════════════════════
        {
            "label": "install-debug-tools",
            "detail": "Download MCU SVD files + install Cortex-Debug extension",
            "type": "shell",
            "command": "bash scripts/install_debug_tools.sh",
            "options": { "cwd": "${workspaceFolder}" },
            "problemMatcher": [],
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "clear": true
            }
        }
    ],

    // ── Input variables ───────────────────────────────────────────────────────
    "inputs": [
        {
            "id": "boardName",
            "type": "promptString",
            "description": "Board name (must match app/board/<name>.xml)",
            "default": "stm32f411_devboard"
        }
    ]
}
