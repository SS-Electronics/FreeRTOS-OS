{
    // ─────────────────────────────────────────────────────────────────────────
    //  FreeRTOS-OS  —  VS Code Debug / Run Configurations
    //
    //  Requires:  marus25.cortex-debug  (Cortex-Debug extension)
    //
    //  HOW TARGET ARCHITECTURE IS AUTO-DETECTED
    //  ─────────────────────────────────────────
    //  Every "Auto" launch config runs  preLaunchTask: "detect-target"  first.
    //  That task calls  scripts/gen_active_debug.py  which reads
    //  include/config/autoconf.h (generated from your Kconfig .config) and
    //  writes build/active_debug.cfg pointing to the correct OpenOCD MCU
    //  config from arch/debug_cfg/.  No manual editing needed when you switch
    //  MCUs — just change CONFIG_TARGET_MCU via  make menuconfig  and rebuild.
    //
    //  CONFIGURATION GROUPS
    //  ────────────────────
    //  ① Auto — Build, Flash & Debug   →  F5 (normal dev workflow)
    //  ② Auto — Attach                 →  attach to already-running target
    //  ③ Auto — Flash Only (Run)       →  program + run, no debug session
    //                                     (equivalent to STM32CubeIDE "Run")
    //  ④ STM32F411xE — explicit config with full SVD peripheral view
    //  ⑤ STM32F401xE — explicit config with full SVD peripheral view
    //
    //  FIRST-TIME SETUP
    //  ────────────────
    //  1. make menuconfig               →  set CONFIG_TARGET_MCU
    //  2. make config-outputs           →  generate include/config/autoconf.h
    //  3. Run VS Code task: install-debug-tools  →  download SVD file
    //  4. Press F5 → "Auto — Build, Flash & Debug"
    // ─────────────────────────────────────────────────────────────────────────

    "version": "0.2.0",
    "configurations": [

        // ══════════════════════════════════════════════════════════════════════
        //  ①  AUTO — Build, Flash & Debug
        //     Reads CONFIG_TARGET_MCU → selects correct OpenOCD cfg → builds
        //     firmware → flashes → starts GDB halted at main().
        //     Equivalent to pressing F5 in STM32CubeIDE.
        // ══════════════════════════════════════════════════════════════════════
        {
            "name": "Auto — Build, Flash & Debug",
            "type": "cortex-debug",
            "request": "launch",

            // ── Auto-generated by detect-target preLaunchTask ────────────────
            // build/active_debug.cfg is written by scripts/gen_active_debug.py.
            // It sources the correct arch/debug_cfg/<mcu>_debug.cfg for the
            // MCU set in CONFIG_TARGET_MCU (autoconf.h).
            "configFiles": [
                "${workspaceFolder}/build/active_debug.cfg"
            ],

            // ── Target binary ─────────────────────────────────────────────────
            "executable": "${workspaceFolder}/build/kernel.elf",

            // ── Toolchain (resolved from PATH — no hardcoded paths) ───────────
            "gdbPath": "arm-none-eabi-gdb",

            // ── Generic Cortex-M4 family; exact chip ID comes from SVD/OpenOCD ─
            "device": "STM32F4xx",
            "interface": "swd",

            // ── SVD — peripheral register viewer ─────────────────────────────
            // active_target.svd is a symlink created by gen_active_debug.py
            // pointing to the MCU-specific SVD (STM32F411.svd, STM32F401.svd …)
            "svdFile": "${workspaceFolder}/arch/debug_cfg/active_target.svd",

            // ── FreeRTOS-aware task/stack view ───────────────────────────────
            "rtos": "FreeRTOS",

            // ── Build + detect target before launching ────────────────────────
            "preLaunchTask": "build-and-detect",

            // ── Run to main() after flash (mirrors CubeIDE default) ──────────
            "runToEntryPoint": "main",

            // ── GDB init commands (before program load) ──────────────────────
            "preLaunchCommands": [
                "set mem inaccessible-by-default off",
                "set print pretty on",
                "set print object on",
                "set pagination off"
            ],

            // ── GDB commands after load, before run ──────────────────────────
            "postLaunchCommands": [
                "monitor reset halt"
            ],

            // ── Debug console verbosity ───────────────────────────────────────
            "showDevDebugOutput": "both",

            // ── SWO / ITM printf — enable if ITM_DEBUG_EN set in os_config.h ─
            "swoConfig": {
                "enabled": false,
                "cpuFrequency": 100000000,
                "swoFrequency": 2000000,
                "source": "probe",
                "decoders": [
                    {
                        "type": "console",
                        "label": "ITM port 0",
                        "port": 0,
                        "encoding": "ascii"
                    }
                ]
            }
        },

        // ══════════════════════════════════════════════════════════════════════
        //  ②  AUTO — Attach (no flash, no reset)
        //     Attaches GDB to a target that is already powered and running.
        //     Use when you want to inspect live state without restarting.
        //     Start the OpenOCD server manually first with the
        //     "openocd-server" task, or just use this — Cortex-Debug will
        //     start OpenOCD automatically.
        // ══════════════════════════════════════════════════════════════════════
        {
            "name": "Auto — Attach",
            "type": "cortex-debug",
            "request": "attach",

            "configFiles": [
                "${workspaceFolder}/build/active_debug.cfg"
            ],
            "executable": "${workspaceFolder}/build/kernel.elf",
            "gdbPath": "arm-none-eabi-gdb",

            "device": "STM32F4xx",
            "interface": "swd",
            "svdFile": "${workspaceFolder}/arch/debug_cfg/active_target.svd",
            "rtos": "FreeRTOS",

            // Only need to detect target (no build/flash for attach)
            "preLaunchTask": "detect-target",

            "postLaunchCommands": [
                "monitor halt",
                "set mem inaccessible-by-default off",
                "set print pretty on",
                "set pagination off"
            ],

            "showDevDebugOutput": "both",

            "swoConfig": {
                "enabled": false,
                "cpuFrequency": 100000000,
                "swoFrequency": 2000000,
                "source": "probe",
                "decoders": [
                    { "type": "console", "label": "ITM port 0", "port": 0 }
                ]
            }
        },

        // ══════════════════════════════════════════════════════════════════════
        //  ③  AUTO — Flash Only (Run)
        //     Programs the ELF into flash and resets — no debug session.
        //     Equivalent to the green "Run" button in STM32CubeIDE.
        // ══════════════════════════════════════════════════════════════════════
        {
            "name": "Auto — Flash Only (Run)",
            "type": "cortex-debug",
            "request": "launch",

            "configFiles": [
                "${workspaceFolder}/build/active_debug.cfg"
            ],
            "executable": "${workspaceFolder}/build/kernel.elf",
            "gdbPath": "arm-none-eabi-gdb",

            "device": "STM32F4xx",
            "interface": "swd",

            "preLaunchTask": "build-and-detect",

            // Load, reset, run, then immediately quit the debug session.
            // The target keeps running autonomously after this.
            "postLaunchCommands": [
                "monitor reset run",
                "disconnect",
                "quit"
            ],

            "runToEntryPoint": "",
            "showDevDebugOutput": "raw"
        },

        // ══════════════════════════════════════════════════════════════════════
        //  ④  STM32F411xE — Explicit (Build, Flash & Debug)
        //     Hard-wired to STM32F411xE OpenOCD config + SVD.
        //     Provides full peripheral register view with exact chip data.
        //     Use when you need the Peripherals panel at its most accurate.
        // ══════════════════════════════════════════════════════════════════════
        {
            "name": "STM32F411xE — Build, Flash & Debug",
            "type": "cortex-debug",
            "request": "launch",

            "configFiles": [
                "${workspaceFolder}/arch/debug_cfg/stm32_f411xx_debug.cfg"
            ],
            "executable": "${workspaceFolder}/build/kernel.elf",
            "gdbPath": "arm-none-eabi-gdb",

            "device": "STM32F411VE",
            "interface": "swd",
            "svdFile": "${workspaceFolder}/arch/debug_cfg/STM32F411.svd",
            "rtos": "FreeRTOS",

            "preLaunchTask": "build",

            "runToEntryPoint": "main",

            "preLaunchCommands": [
                "set mem inaccessible-by-default off",
                "set print pretty on",
                "set print object on",
                "set pagination off"
            ],
            "postLaunchCommands": [
                "monitor reset halt"
            ],

            "showDevDebugOutput": "both",

            "swoConfig": {
                "enabled": false,
                "cpuFrequency": 100000000,
                "swoFrequency": 2000000,
                "source": "probe",
                "decoders": [
                    { "type": "console", "label": "ITM port 0", "port": 0, "encoding": "ascii" }
                ]
            }
        },

        // ══════════════════════════════════════════════════════════════════════
        //  ⑤  STM32F401xE — Explicit (Build, Flash & Debug)
        //     Hard-wired to STM32F401xE OpenOCD config + SVD.
        // ══════════════════════════════════════════════════════════════════════
        {
            "name": "STM32F401xE — Build, Flash & Debug",
            "type": "cortex-debug",
            "request": "launch",

            "configFiles": [
                "${workspaceFolder}/arch/debug_cfg/stm32_f401xx_debug.cfg"
            ],
            "executable": "${workspaceFolder}/build/kernel.elf",
            "gdbPath": "arm-none-eabi-gdb",

            "device": "STM32F401xE",
            "interface": "swd",
            "svdFile": "${workspaceFolder}/arch/debug_cfg/STM32F401.svd",
            "rtos": "FreeRTOS",

            "preLaunchTask": "build",

            "runToEntryPoint": "main",

            "preLaunchCommands": [
                "set mem inaccessible-by-default off",
                "set print pretty on",
                "set print object on",
                "set pagination off"
            ],
            "postLaunchCommands": [
                "monitor reset halt"
            ],

            "showDevDebugOutput": "both",

            "swoConfig": {
                "enabled": false,
                "cpuFrequency": 84000000,
                "swoFrequency": 2000000,
                "source": "probe",
                "decoders": [
                    { "type": "console", "label": "ITM port 0", "port": 0, "encoding": "ascii" }
                ]
            }
        }
    ]
}
