{
    // ─────────────────────────────────────────────────────────────────────────
    //  FreeRTOS-OS  —  Workspace Settings
    //
    //  MACHINE-AGNOSTIC TOOL PATHS
    //  ────────────────────────────
    //  Tool paths below use empty strings so Cortex-Debug / the C++ extension
    //  discovers tools from PATH.  To override on a per-machine basis, create
    //  a .vscode/settings.local.json (gitignored) and set paths there, e.g.:
    //
    //    {
    //      "cortex-debug.armToolchainPath": "/opt/gcc-arm-none-eabi-13/bin",
    //      "cortex-debug.openocdPath": "/usr/local/bin/openocd"
    //    }
    //
    //  Alternatively export environment variables before launching VS Code:
    //    export PATH="/opt/gcc-arm-none-eabi-13/bin:$PATH"
    // ─────────────────────────────────────────────────────────────────────────

    // ── Cortex-Debug: tool discovery (empty = use PATH) ───────────────────────
    // Override in settings.local.json if your tools are in a non-standard path.
    "cortex-debug.armToolchainPath": "",
    "cortex-debug.openocdPath": "",
    "cortex-debug.gdbPath": "",

    // FreeRTOS kernel source — enables stepping into kernel code in the debugger
    "cortex-debug.rtos.freertos.kernelPath": "${workspaceFolder}/kernel/FreeRTOS-Kernel",

    // Show values in their natural format (decimal ints, not always hex)
    "cortex-debug.variableUseNaturalFormat": true,

    // ── C/C++ extension ───────────────────────────────────────────────────────
    // compilerPath is resolved from PATH (no hardcoded /usr/bin prefix)
    "C_Cpp.default.compilerPath": "arm-none-eabi-gcc",
    "C_Cpp.default.intelliSenseMode": "gcc-arm",
    "C_Cpp.default.cStandard": "gnu99",
    "C_Cpp.errorSquiggles": "enabled",

    // ── Editor ────────────────────────────────────────────────────────────────
    "editor.formatOnSave": false,
    "editor.tabSize": 4,
    "editor.insertSpaces": true,
    "editor.rulers": [100],

    // ── File associations ─────────────────────────────────────────────────────
    "files.associations": {
        "*.h":   "c",
        "*.c":   "c",
        "*.ld":  "plaintext",
        "*.cfg": "tcl",
        "*.xml": "xml",
        "*.svd": "xml",
        "*.s":   "asm",
        "*.S":   "asm"
    },

    // ── File explorer: hide build artifacts, keep sources visible ─────────────
    "files.exclude": {
        "build/":                                  true,
        "**/*.o":                                  true,
        "**/*.d":                                  true,
        "com_stack/canopen-stack/":                true
    },

    // ── Search: exclude large vendored subtrees ───────────────────────────────
    "search.exclude": {
        "build/":                                         true,
        "arch/arm/CMSIS_6/":                              true,
        "arch/devices/STM/stm32f4xx-hal-driver/":         true,
        "kernel/FreeRTOS-Kernel/":                        true,
        "com_stack/":                                     true
    },

    // ── Terminal ──────────────────────────────────────────────────────────────
    "terminal.integrated.defaultProfile.linux":   "bash",
    "terminal.integrated.defaultProfile.windows": "Command Prompt",
    "terminal.integrated.defaultProfile.osx":     "bash",

    // ── Makefile tools extension ──────────────────────────────────────────────
    "makefile.makePath": "make",
    "makefile.buildLog": "${workspaceFolder}/build/make.log"
}
