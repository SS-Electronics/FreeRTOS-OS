{
    // ─────────────────────────────────────────────────────────────────────────
    //  FreeRTOS-OS  —  IntelliSense Configuration
    //
    //  One configuration per supported MCU target.
    //  Switch the active config via the bottom-right status bar selector
    //  (C/C++ extension: "Select Configuration").
    //
    //  compilerPath is left as the bare tool name so the C/C++ extension
    //  discovers it from PATH.  Set ARM_GCC_PATH in your environment (or
    //  in settings.json) to override:
    //    ARM_GCC_PATH=/opt/gcc-arm/bin  make ...
    // ─────────────────────────────────────────────────────────────────────────
    "configurations": [

        // ── STM32F411xE (primary target — Nucleo-F411RE / dev-board) ─────────
        {
            "name": "STM32F411xE",
            "includePath": [
                "${workspaceFolder}",
                "${workspaceFolder}/include",
                "${workspaceFolder}/include/config",
                "${workspaceFolder}/include/services",
                "${workspaceFolder}/include/board",
                "${workspaceFolder}/include/ipc",
                "${workspaceFolder}/include/mm",
                "${workspaceFolder}/include/os",
                "${workspaceFolder}/include/drivers",
                "${workspaceFolder}/include/lib",
                "${workspaceFolder}/arch/arm/CMSIS_6",
                "${workspaceFolder}/arch/devices/STM/STM32F4xx",
                "${workspaceFolder}/arch/devices/STM/STM32F4xx/STM32F411",
                "${workspaceFolder}/arch/devices/STM/stm32f4xx-hal-driver/Inc",
                "${workspaceFolder}/kernel",
                "${workspaceFolder}/kernel/FreeRTOS-Kernel/include",
                "${workspaceFolder}/kernel/FreeRTOS-Kernel/portable/GCC/ARM_CM4F",
                "${workspaceFolder}/lib",
                // Application headers (when workspace opened inside FreeRTOS-OS/)
                "${workspaceFolder}/../app",
                "${workspaceFolder}/../app/board"
            ],
            "defines": [
                "STM32F411xE",
                "USE_HAL_DRIVER",
                "__ARM_ARCH_7EM__",
                "__FPU_PRESENT=1",
                "ARM_MATH_CM4"
            ],
            "compilerPath": "arm-none-eabi-gcc",
            "cStandard": "gnu99",
            "cppStandard": "gnu++14",
            "intelliSenseMode": "gcc-arm",
            "forcedInclude": [
                "${workspaceFolder}/include/config/autoconf.h"
            ]
        },

        // ── STM32F401xE (secondary target) ───────────────────────────────────
        {
            "name": "STM32F401xE",
            "includePath": [
                "${workspaceFolder}",
                "${workspaceFolder}/include",
                "${workspaceFolder}/include/config",
                "${workspaceFolder}/include/services",
                "${workspaceFolder}/include/board",
                "${workspaceFolder}/include/ipc",
                "${workspaceFolder}/include/mm",
                "${workspaceFolder}/include/os",
                "${workspaceFolder}/include/drivers",
                "${workspaceFolder}/include/lib",
                "${workspaceFolder}/arch/arm/CMSIS_6",
                "${workspaceFolder}/arch/devices/STM/STM32F4xx",
                "${workspaceFolder}/arch/devices/STM/STM32F4xx/STM32F401",
                "${workspaceFolder}/arch/devices/STM/stm32f4xx-hal-driver/Inc",
                "${workspaceFolder}/kernel",
                "${workspaceFolder}/kernel/FreeRTOS-Kernel/include",
                "${workspaceFolder}/kernel/FreeRTOS-Kernel/portable/GCC/ARM_CM4F",
                "${workspaceFolder}/lib",
                "${workspaceFolder}/../app",
                "${workspaceFolder}/../app/board"
            ],
            "defines": [
                "STM32F401xE",
                "USE_HAL_DRIVER",
                "__ARM_ARCH_7EM__",
                "__FPU_PRESENT=1",
                "ARM_MATH_CM4"
            ],
            "compilerPath": "arm-none-eabi-gcc",
            "cStandard": "gnu99",
            "cppStandard": "gnu++14",
            "intelliSenseMode": "gcc-arm",
            "forcedInclude": [
                "${workspaceFolder}/include/config/autoconf.h"
            ]
        }
    ],
    "version": 4
}
