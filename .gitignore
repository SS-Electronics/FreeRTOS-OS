*.d

# Object files
*.o
*.ko
*.obj
*.elf

# Linker output (scoped to /build/ so Doxygen image maps in docs/ are not blocked)
*.ilk
/build/*.map
*.exp

# Precompiled Headers
*.gch
*.pch

# Libraries
*.lib
*.a
*.la
*.lo

# Shared objects (inc. Windows DLLs)
*.dll
*.so
*.so.*
*.dylib

# Executables
*.exe
*.out
*.app
*.i*86
*.x86_64
*.hex

# Debug files
*.dSYM/
*.su
*.idb
*.pdb

# Kernel Module Compile Results
*.mod*
*.cmd
.tmp_versions/


# Ignore build output
/build/


.config
.config.old

autoconf.mk

# Generated configuration headers (make config-outputs)
config/autoconf.h
arch/devices/device_conf/

modules.order
Module.symvers
Mkfile.old
dkms.conf

# ── Demo build generated outputs ──────────────────────────────────────────────
# Recreated by: make demo-gen
# Source files (tracked): demo/board/*.xml  demo/board/mcu_config.h
#                         demo/kconfig.conf demo/app_main.c demo/Makefile
#                         demo/os_conf_include/
demo/board/irq_hw_conf.h
demo/board/irq_hw_init_generated.c
demo/board/irq_hw_init_generated.h
demo/board/irq_periph_dispatch_generated.c
demo/board/irq_periph_handlers_generated.h
demo/board/irq_periph_vectors_generated.inc
demo/board/irq_table_generated.c
demo/board/board_config.c
demo/board/board_config.h
demo/board/board_device_ids.h
demo/board/board_handles.h

# ── Static analysis (CPPcheck + MISRA) ────────────────────────────────────────
# Generated reports — run ./scripts/run_cppcheck.sh to regenerate
reports/

# cppcheck intermediate files (generated and cleaned by run_cppcheck.sh)
*.dump
*.ctu-info

# ── Doxygen generated output ─────────────────────────────────────────────────
# HTML docs are regenerated with: make docs  (or: doxygen Doxyfile)
docs/*.html
docs/*.js
docs/*.css
docs/*.png
docs/*.svg
docs/*.map
docs/*.md5
docs/*.dot
docs/search/
docs/doxygen_sqlite3.db

# ── CI/CD local artefacts ─────────────────────────────────────────────────────
.act/
ci-reports/
