*.d

# Object files
*.o
*.ko
*.obj
*.elf

# Linker output (scoped to /build/ so Doxygen image maps in docs/ are not blocked)
*.ilk
/build/*.map
*.exp

# Precompiled Headers
*.gch
*.pch

# Libraries
*.lib
*.a
*.la
*.lo

# Shared objects (inc. Windows DLLs)
*.dll
*.so
*.so.*
*.dylib

# Executables
*.exe
*.out
*.app
*.i*86
*.x86_64
*.hex

# Debug files
*.dSYM/
*.su
*.idb
*.pdb

# Kernel Module Compile Results
*.mod*
*.cmd
.tmp_versions/


# Ignore build output
/build/


.config
.config.old

autoconf.mk

# Generated configuration headers (make config-outputs)
config/autoconf.h
arch/devices/device_conf/

modules.order
Module.symvers
Mkfile.old
dkms.conf

# ── Devboard example generated outputs ───────────────────────────────────────
# Each examples/<devboard>/board/ has a fixed set of generator outputs, all
# recreated by  make dev-<devboard>-gen  (or by the umbrella  make dev-<devboard>).
# Tracked inputs in each examples/<devboard>/:
#     <devboard>.xml, irq_table.xml, mcu_config.h, kconfig.conf,
#     app_main.c, Makefile, os_conf_include/
examples/*/board/irq_hw_conf.h
examples/*/board/irq_hw_init_generated.c
examples/*/board/irq_hw_init_generated.h
examples/*/board/irq_periph_dispatch_generated.c
examples/*/board/irq_periph_handlers_generated.h
examples/*/board/irq_periph_vectors_generated.inc
examples/*/board/irq_table_generated.c
examples/*/board/board_config.c
examples/*/board/board_config.h
examples/*/board/board_device_ids.h
examples/*/board/board_handles.h

# ── Static analysis (CPPcheck + MISRA) ────────────────────────────────────────
# Generated reports — run ./scripts/run_cppcheck.sh to regenerate
reports/

# cppcheck intermediate files (generated and cleaned by run_cppcheck.sh)
*.dump
*.ctu-info

# ── Doxygen generated output ─────────────────────────────────────────────────
# HTML docs are regenerated with: make docs  (or: doxygen Doxyfile)
docs/*.html
docs/*.js
docs/*.css
docs/*.png
docs/*.svg
docs/*.map
docs/*.md5
docs/*.dot
docs/search/
docs/doxygen_sqlite3.db

# ── CI/CD local artefacts ─────────────────────────────────────────────────────
.act/
ci-reports/
